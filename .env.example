# =============================================================
# SISTEMA GRIFO — Variables de entorno (frontend Vite)
# =============================================================
# 1. Copia este archivo: cp .env.example .env
# 2. Completa los valores reales
# 3. NUNCA subas el .env al repositorio (ya está en .gitignore)
# =============================================================

# --- Supabase (obtener en: supabase.com → tu proyecto → Settings → API) ---
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- App ---
VITE_APP_NAME=Sistema Grifo
# Valores: development | production
VITE_APP_ENV=development
