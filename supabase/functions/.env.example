# =============================================================
# SISTEMA GRIFO — Secretos para Supabase Edge Functions
# =============================================================
# Para desarrollo LOCAL con Supabase CLI:
#   1. Copia: cp supabase/functions/.env.example supabase/functions/.env
#   2. Completa los valores
#   3. Ejecuta: supabase start
#
# Para producción (Supabase remoto):
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=tu_clave
#   supabase secrets set OSINERGMIN_EXCEL_URL=url_del_excel
#
# NUNCA subas el .env real al repositorio.
# =============================================================

# --- Supabase (obtener en: supabase.com → Settings → API) ---
# La ANON_KEY es pública (frontend). La SERVICE_ROLE_KEY es privada (solo servidor).
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- OSINERGMIN ---
# URL de descarga del Excel de últimos precios registrados EVPC
OSINERGMIN_EXCEL_URL=https://www.osinergmin.gob.pe/empresas/hidrocarburos/scop/documentos-scop
